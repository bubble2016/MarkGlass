{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkGlass",
  "version": "1.0.1",
  "identifier": "com.win8en.markglass",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkGlass",
        "width": 1440,
        "height": 900,
        "minWidth": 520,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "maximized": true,
        "shadow": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "mdx",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Open Markdown with MarkGlass",
        "role": "Viewer"
      }
    ]
  }
}
